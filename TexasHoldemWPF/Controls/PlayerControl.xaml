<UserControl x:Class="TexasHoldemWPF.Controls.PlayerControl"
             x:Name="root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:TexasHoldemWPF.Resources.Converters"
             xmlns:controls="clr-namespace:TexasHoldemWPF.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="130" d:DesignWidth="400">

    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:BalanceToKConverter x:Key="BalanceToKConverter"/>
        <converters:FoldedToOpacityConverter x:Key="FoldedToOpacityConverter"/>
        <converters:ActionToVisibilityConverter x:Key="ActionToVisibilityConverter"/>
        <converters:ActionToColorConverter x:Key="ActionToColorConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid HorizontalAlignment="Left" VerticalAlignment="Center" Margin="2,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Width="90" Height="90" ZIndex="1" Margin="0,0,-45,0" VerticalAlignment="Center">
                <Ellipse Fill="LightGray" Stroke="White" StrokeThickness="2"/>
                <Image Source="pack://application:,,,/Resources/images/Male.png" Width="60" Height="60"/>
            </Grid>

            <Border Grid.Column="1" Background="Gray" CornerRadius="5" 
                    Height="60" MinWidth="220"
                    Opacity="{Binding Player.IsFolded, ElementName=root, Converter={StaticResource FoldedToOpacityConverter}}"
                    VerticalAlignment="Center" Margin="0" Width="150">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="3" BlurRadius="10" Opacity="0.5"/>
                </Border.Effect>

                <Grid Margin="60,0,10,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{Binding Player.Name, ElementName=root}"
                               FontSize="16"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Bottom"
                               Margin="0,2,0,0"/>
                    <Separator Grid.Row="1" Height="1" Background="White" Margin="0"/>
                    <TextBlock Grid.Row="2"
                               Text="{Binding Player.Balance, ElementName=root, Converter={StaticResource BalanceToKConverter}}"
                               FontSize="16" Foreground="Gold"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Top"
                               Margin="0,0,0,2"/>
                </Grid>
            </Border>

            <ItemsControl Grid.Column="2" ItemsSource="{Binding Cards, ElementName=root}" Visibility="{Binding ShowCards, ElementName=root, Converter={StaticResource BoolToVisibilityConverter}}" 
                          VerticalAlignment="Center" Margin="0,0,50,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Image Source="{Binding ImagePath}" Width="70" Height="100" Margin="4"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <Grid HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
            <Ellipse Width="24" Height="24" Fill="LightGray" Stroke="White" StrokeThickness="1"
                     Visibility="{Binding IsDealer, ElementName=root, Converter={StaticResource BoolToVisibilityConverter}}" Margin="-287,-26,287,67"/>
            <TextBlock Text="D" FontSize="14" Foreground="Black" FontWeight="Bold"
                       HorizontalAlignment="Left" VerticalAlignment="Top"
                       Visibility="{Binding IsDealer, ElementName=root, Converter={StaticResource BoolToVisibilityConverter}}" Margin="-280,-24,0,0"/>
        </Grid>

        <controls:ActionControl x:Name="ActionDisplay"
            HorizontalAlignment="Left" 
            VerticalAlignment="Bottom"
            Margin="127,0,0,0"
            ActionText="{Binding Player.LastAction, ElementName=root}"
            BackgroundColor="{Binding Player.LastAction, ElementName=root, Converter={StaticResource ActionToColorConverter}}"
            Visibility="{Binding Player.LastAction, ElementName=root, Converter={StaticResource ActionToVisibilityConverter}}"/>
    </Grid>
</UserControl>