<UserControl x:Class="TexasHoldemWPF.Controls.MenuControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:TexasHoldemWPF.Resources.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="300">
    <UserControl.Resources>
        <converters:BalanceToKConverter x:Key="BalanceToKConverter"/>
    </UserControl.Resources>
    <Border BorderBrush="Gold" BorderThickness="4" CornerRadius="5" Background="White">
        <Grid Background="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="200"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="Black" CornerRadius="3,3,0,0">
                <TextBlock Text="TOURNAMENT" 
                           Foreground="Gold" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           Padding="10,5"/>
            </Border>

            <TextBlock Grid.Row="1" 
                       Text="{Binding City, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       Padding="10,5" 
                       Background="White"
                       Foreground="Black"/>

            <Image Grid.Row="2" 
                   Source="{Binding ImagePath, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Stretch="UniformToFill"
                   Width="300"
                   Height="200"/>

            <TextBlock Grid.Row="3" 
                       Text="PRIZE" 
                       FontSize="15" 
                       HorizontalAlignment="Center" 
                       Padding="10,5" 
                       Background="White"
                       Foreground="Black"/>

            <TextBlock Grid.Row="4" 
                       Text="{Binding Prize, Converter={StaticResource BalanceToKConverter}, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                       FontSize="28" 
                       Foreground="Red" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       Padding="10,0" 
                       Background="White"/>

            <Line Grid.Row="5" 
                  X1="0" 
                  X2="300" 
                  Stroke="Red" 
                  StrokeThickness="2" 
                  Margin="0,10" 
                  HorizontalAlignment="Center"/>

            <TextBlock Grid.Row="6" 
                       Text="{Binding BuyIn, Converter={StaticResource BalanceToKConverter}, StringFormat=Buy-in {0}, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                       FontSize="16" 
                       HorizontalAlignment="Center" 
                       Padding="10,5" 
                       Background="White"
                       Foreground="Black"/>

            <Border Grid.Row="7" Background="White" Padding="0,0,0,10">
                <Button Content="JOIN" 
                        Command="{Binding Command, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding CommandParameter, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        Background="#FF0078D7" 
                        Foreground="White" 
                        FontSize="16" 
                        FontWeight="Bold" 
                        Margin="20,10" 
                        Padding="10,5"
                        Width="200"/>
            </Border>
        </Grid>
    </Border>
</UserControl>