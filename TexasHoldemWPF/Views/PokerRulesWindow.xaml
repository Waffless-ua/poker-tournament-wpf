<Window x:Class="TexasHoldemWPF.Views.PokerRulesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Texas Hold'em Rules" 
        Width="850"
        Height="750"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <Style x:Key="GoldButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#FFD700"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Foreground" Value="#FFD700"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#30FFD700"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#60FFD700"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CustomScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                   Orientation="Vertical"
                                   Width="8"
                                   HorizontalAlignment="Right">
                                <ScrollBar.Template>
                                    <ControlTemplate TargetType="ScrollBar">
                                        <Grid>
                                            <Track x:Name="PART_Track"
                                               IsDirectionReversed="true">
                                                <Track.Thumb>
                                                    <Thumb Background="#FFD700"/>
                                                </Track.Thumb>
                                            </Track>
                                        </Grid>
                                    </ControlTemplate>
                                </ScrollBar.Template>
                            </ScrollBar>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DropShadowEffect x:Key="CardShadowEffect" 
                      BlurRadius="20" 
                      ShadowDepth="5" 
                      Color="Black" 
                      Opacity="0.7"/>
    </Window.Resources>
    <Border CornerRadius="15" 
            Background="#FF2D2D30" 
            BorderBrush="#FF0078D7" 
            BorderThickness="2">
        <Grid>

            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" 
                        CornerRadius="10"
                        Background="#3A3A3A"
                        Padding="15"
                        BorderBrush="#FFD700"
                        BorderThickness="1"
                        Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Image Source="pack://application:,,,/Resources/Icons/Chip.png"
                               Width="50" Height="50" Margin="0,0,15,0"
                               RenderTransformOrigin="0.5,0.5">
                            <Image.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </Image.RenderTransform>
                            <Image.Triggers>
                                <EventTrigger RoutedEvent="MouseEnter">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Angle"
                                                             To="360" Duration="0:0:1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Image.Triggers>
                        </Image>
                        <TextBlock Text="TEXAS HOLD'EM RULES" 
                                   FontSize="28" 
                                   FontWeight="Bold"
                                   Foreground="#FFD700"
                                   FontFamily="Arial"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" 
                              Margin="0,0,0,20"
                              VerticalScrollBarVisibility="Auto"
                              Style="{StaticResource CustomScrollViewer}">
                    <StackPanel>
                        <Border CornerRadius="8"
                                Background="#3A3A3A"
                                Padding="15"
                                Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="GAME FLOW" 
                                           FontSize="20" 
                                           FontWeight="Bold"
                                           Foreground="#FFD700"
                                           Margin="0,0,0,10"/>

                                <StackPanel Margin="10,0">
                                    <TextBlock Text="1. Each player is dealt 2 private cards (hole cards)" 
                                               Foreground="White"
                                               Margin="0,5"
                                               FontSize="16"/>
                                    <TextBlock Text="2. There are 4 betting rounds:" 
                                               Foreground="White"
                                               Margin="0,5"
                                               FontSize="16"/>
                                    <TextBlock Text="   a) Pre-flop (after receiving hole cards)" 
                                               Foreground="#CCCCCC"
                                               Margin="20,5"
                                               FontSize="14"/>
                                    <TextBlock Text="   b) Flop (after first 3 community cards)" 
                                               Foreground="#CCCCCC"
                                               Margin="20,5"
                                               FontSize="14"/>
                                    <TextBlock Text="   c) Turn (after 4th community card)" 
                                               Foreground="#CCCCCC"
                                               Margin="20,5"
                                               FontSize="14"/>
                                    <TextBlock Text="   d) River (after 5th community card)" 
                                               Foreground="#CCCCCC"
                                               Margin="20,5"
                                               FontSize="14"/>
                                    <TextBlock Text="3. Players make their best 5-card hand using any combination of their hole cards and community cards" 
                                               Foreground="White"
                                               Margin="0,5"
                                               FontSize="16"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="4. The player with the best hand wins the pot" 
                                               Foreground="White"
                                               Margin="0,5"
                                               FontSize="16"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="8"
                                Background="#3A3A3A"
                                Padding="15">
                            <StackPanel>
                                <TextBlock Text="BETTING RULES" 
                                           FontSize="20" 
                                           FontWeight="Bold"
                                           Foreground="#FFD700"
                                           Margin="0,0,0,10"/>

                                <ItemsControl ItemsSource="{Binding BettingRules}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" 
                                                       Foreground="White"
                                                       Margin="10,5"
                                                       FontSize="16"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Button Grid.Row="2" 
                        Content="CLOSE" 
                        Click="CloseButton_Click"
                        HorizontalAlignment="Center"
                        Width="150"
                        Height="45"
                        Margin="0,10"
                        Style="{StaticResource GoldButtonStyle}"/>
            </Grid>
        </Grid>
    </Border>
</Window>