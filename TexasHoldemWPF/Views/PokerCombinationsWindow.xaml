<Window x:Class="TexasHoldemWPF.Views.PokerCombinationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TexasHoldemWPF.Views"
        mc:Ignorable="d"
        Title="Texas Hold'em Rules" 
        Width="850" 
        Height="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <DropShadowEffect x:Key="DropShadowEffect" BlurRadius="10" ShadowDepth="3" Color="Black"/>
        <Style x:Key="CustomScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                   Orientation="Vertical"
                                   Width="8"
                                   HorizontalAlignment="Right">
                                <ScrollBar.Template>
                                    <ControlTemplate TargetType="ScrollBar">
                                        <Grid>
                                            <Track x:Name="PART_Track"
                                               IsDirectionReversed="true">
                                                <Track.Thumb>
                                                    <Thumb Background="#FFD700"/>
                                                </Track.Thumb>
                                            </Track>
                                        </Grid>
                                    </ControlTemplate>
                                </ScrollBar.Template>
                            </ScrollBar>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GoldButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#FFD700"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Foreground" Value="#FFD700"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#30FFD700"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#60FFD700"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border CornerRadius="15" 
            Background="#FF2D2D30" 
            BorderBrush="#FF0078D7" 
            BorderThickness="2"
            Effect="{StaticResource DropShadowEffect}">

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" 
                        CornerRadius="10"
                        Background="#3A3A3A"
                        Padding="15"
                        BorderBrush="#FFD700"
                        BorderThickness="1"
                        Margin="0,0,0,20">
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Image Source="pack://application:,,,/Resources/Icons/Chip.png"
                       Width="40" Height="40" Margin="0,0,10,0"/>
                    <TextBlock Text="Poker Hand Rankings" 
                           FontSize="28" 
                            FontWeight="Bold"
                            Foreground="#FFD700"
                            FontFamily="Arial"
                            VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            <ScrollViewer Grid.Row="1" Margin="0,20" VerticalScrollBarVisibility="Auto" Style="{StaticResource CustomScrollViewer}">
                <ItemsControl ItemsSource="{Binding Hands}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#3A3A3A" 
                                    CornerRadius="5" 
                                    Padding="15"
                                    Margin="0,0,0,15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Image Grid.Column="0" 
                                           Source="{Binding ImagePath}"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"/>

                                    <StackPanel Grid.Column="1" Margin="15,0,0,0">
                                        <TextBlock Text="{Binding Name}" 
                                                   FontSize="20" 
                                                   FontWeight="Bold"
                                                   Foreground="Gold"/>
                                        <TextBlock Text="{Binding Description}" 
                                                   Foreground="White"
                                                   Margin="0,5,0,0"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Button Grid.Row="2" 
                    Content="CLOSE" 
                    HorizontalAlignment="Center" 
                    Width="150" 
                    Height="40"
                    Margin="0,20,0,0"
                    Click="CloseButton_Click"
                    Style="{StaticResource GoldButtonStyle}"/>
        </Grid>
    </Border>
</Window>