<Page
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="TexasHoldemWPF.Views.WinView"
      Background="#FF2D2D30" Height="284" Width="488">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="{Binding Message}" 
                       FontSize="98" 
                       Foreground="#FFD700" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>
            <TextBlock Text="{Binding SubMessage}" 
                       FontSize="46" 
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>