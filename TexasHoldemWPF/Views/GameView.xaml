<Page x:Class="TexasHoldemWPF.Views.GameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:TexasHoldemWPF.Resources.Converters"
             xmlns:controls="clr-namespace:TexasHoldemWPF.Controls"
             mc:Ignorable="d" 
             x:Name="root"
             d:DesignHeight="768" d:DesignWidth="1024">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:BalanceToKConverter x:Key="BalanceToKConverter"/>
        <converters:FoldedToOpacityConverter x:Key="FoldedToOpacityConverter"/>
        <converters:RaiseOptionConverter x:Key="RaiseOptionConverter"/>
        <BlurEffect x:Key="BackgroundBlurEffect" Radius="10"/>
        <Style x:Key="TransparentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF0078D7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Width" Value="60"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                            Background="{TemplateBinding Background}"
                            CornerRadius="360">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0066CC"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="5" ShadowDepth="2" Color="#400078D7"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#004D99"/>
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="pack://application:,,,/Resources/images/Table-background.jpg"/>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" 
                    HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,50">
            <TextBlock Text="Pot: $" Foreground="White" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="{Binding PotSize}" Foreground="White" FontSize="24" FontWeight="Bold" Margin="5,0"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" 
                    HorizontalAlignment="Center" VerticalAlignment="Center">
            <ItemsControl ItemsSource="{Binding CommunityCards}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Image Source="{Binding ImagePath}" Width="80" Height="120" Margin="5"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
        <controls:PlayerControl Grid.Row="1" Grid.Column="0"
            Player="{Binding Players[1]}"
            Cards="{Binding Bot1Cards}"
            IsDealer="{Binding DealerPositions[1]}"
            IsSmallBlind="{Binding SmallBlindPositions[1]}"
            IsBigBlind="{Binding BigBlindPositions[1]}"
            ShowCards="{Binding ShowAllCards}"
            HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <controls:PlayerControl Grid.Row="0" Grid.Column="0"
            Player="{Binding Players[2]}"
            Cards="{Binding Bot2Cards}"
            IsDealer="{Binding DealerPositions[2]}"
            IsSmallBlind="{Binding SmallBlindPositions[2]}"
            IsBigBlind="{Binding BigBlindPositions[2]}"
            ShowCards="{Binding ShowAllCards}"
            HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <controls:PlayerControl Grid.Row="0" Grid.Column="2"
            Player="{Binding Players[3]}"
            Cards="{Binding Bot3Cards}"
            IsDealer="{Binding DealerPositions[3]}"
            IsSmallBlind="{Binding SmallBlindPositions[3]}"
            IsBigBlind="{Binding BigBlindPositions[3]}"
            ShowCards="{Binding ShowAllCards}"
            HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <controls:PlayerControl Grid.Row="1" Grid.Column="2"
            Player="{Binding Players[4]}"
            Cards="{Binding Bot4Cards}"
            IsDealer="{Binding DealerPositions[4]}"
            IsSmallBlind="{Binding SmallBlindPositions[4]}"
            IsBigBlind="{Binding BigBlindPositions[4]}"
            ShowCards="{Binding ShowAllCards}"
            HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <controls:PlayerControl Grid.Row="2" Grid.Column="1"
            Player="{Binding Players[0]}"
            Cards="{Binding PlayerCards}"
            IsDealer="{Binding DealerPositions[0]}"
            IsSmallBlind="{Binding SmallBlindPositions[0]}"
            IsBigBlind="{Binding BigBlindPositions[0]}"
            ShowCards="True"
            HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <StackPanel Grid.Row="2" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="20">
            <Button Content="Fold" Command="{Binding FoldCommand}" 
                Background="#FF0078D7" Foreground="White" 
                Width="100" Height="40" Margin="5" Padding="5" 
                FontSize="16" FontWeight="Bold"
                CommandParameter="{Binding CanAct}"/>
            <Button Content="{Binding CallCheckButtonText}" Command="{Binding CallCommand}" 
                Background="#FF107C10" Foreground="White" 
                Width="100" Height="40" Margin="5" Padding="5" 
                FontSize="16" FontWeight="Bold"
                CommandParameter="{Binding CanAct}"/>
            <Button Content="Raise" Command="{Binding RaiseCommand}" 
                Background="#FFD13438" Foreground="White" 
                Width="100" Height="40" Margin="5" Padding="5" 
                FontSize="16" FontWeight="Bold"
                CommandParameter="{Binding CanAct}"/>
        </StackPanel>

        <Grid Grid.Row="0" Grid.RowSpan="3" Grid.Column="0" Grid.ColumnSpan="3"
      Background="#80000000" Visibility="{Binding IsRaiseMenuVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#FF2D2D30" CornerRadius="10" Width="300" Height="300"
            HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Margin="10">
                    <TextBlock Text="Select raise amount:" Foreground="White" FontSize="18"
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <ItemsControl ItemsSource="{Binding RaiseOptions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}"
                                Command="{Binding DataContext.ExecuteRaiseCommand, ElementName=root}"
                                CommandParameter="{Binding}"
                                Background="#FF0078D7" Foreground="White" 
                                Width="200" Height="40" Margin="5"
                                FontSize="16" FontWeight="Bold"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    CommandParameter="0"
                    Background="#FFD13438" Foreground="White" 
                    Width="200" Height="40" Margin="5"
                    FontSize="16" FontWeight="Bold"/>

                </StackPanel>
            </Border>
        </Grid>
        <Button x:Name="ReturnButton"
            HorizontalAlignment="Left" VerticalAlignment="Top"
            Margin="20" 
            Width="40"
            Height="40"
            Command="{Binding ReturnToMenuCommand}"
            Style="{StaticResource TransparentButtonStyle}"
            ToolTip="Show poker rules">
            <Image Source="pack://application:,,,/Resources/Icons/Back.png"
               Stretch="Uniform"/>
        </Button>
        <Button x:Name="CombinationsButton" Grid.Row="2"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Margin="10,10,20,10"
            Width="40"
            Height="40"
            Command="{Binding ShowCombinationsCommand}"
            Style="{StaticResource TransparentButtonStyle}"
            ToolTip="Show all combinations">
            <Image Source="pack://application:,,,/Resources/Icons/QMark.png"
               Stretch="Uniform"/>
        </Button>
    </Grid>
</Page>